{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/",
      "destination": "/ar/shop",
      "statusCode": 307,
      "regex": "^(?!/_next)/(?:/)?$"
    },
    {
      "source": "/en",
      "destination": "/en/shop",
      "statusCode": 307,
      "regex": "^(?!/_next)/en(?:/)?$"
    },
    {
      "source": "/ar",
      "destination": "/ar/shop",
      "statusCode": 307,
      "regex": "^(?!/_next)/ar(?:/)?$"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        }
      ],
      "regex": "^(?:/(.*))(?:/)?$"
    },
    {
      "source": "/:locale(en|ar)/shop",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=300, stale-while-revalidate=600"
        }
      ],
      "regex": "^(?:/(en|ar))/shop(?:/)?$"
    },
    {
      "source": "/:locale(en|ar)/(dashboard|orders|invoices|payments|credit-notes|profile|account-statement)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, s-maxage=60, stale-while-revalidate=120"
        }
      ],
      "regex": "^(?:/(en|ar))(?:/(dashboard|orders|invoices|payments|credit-notes|profile|account-statement))(?:/)?$"
    },
    {
      "source": "/:path*.(ico|jpg|jpeg|png|gif|webp|svg|avif)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ],
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:\\.(ico|jpg|jpeg|png|gif|webp|svg|avif))(?:/)?$"
    },
    {
      "source": "/:path*.(woff|woff2|ttf|otf)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ],
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:\\.(woff|woff2|ttf|otf))(?:/)?$"
    },
    {
      "source": "/_next/static/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ],
      "regex": "^/_next/static(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    },
    {
      "source": "/_next/image",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=604800, stale-while-revalidate=86400"
        }
      ],
      "regex": "^/_next/image(?:/)?$"
    }
  ],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/api/images/[itemId]",
